  </diagram>
  <diagram id="244425bc-ed85-475d-a7ea-8e39679c099d" name="09 Website - Treatment Ladder">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;Spine Care Treatment Ladder&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="1520" height="66" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="A simplified way to show patients that care may move from least invasive options to advanced procedures when clinically appropriate." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#475569;fontSize=14;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="48" y="101" width="1504" height="44" as="geometry" />
        </mxCell>
        <mxCell id="left_panel" value="&lt;b&gt;Not every patient starts at the same step.&lt;/b&gt;&lt;br&gt;&lt;br&gt;Care decisions depend on symptoms, exam findings, imaging, neurologic safety, prior treatment, health history, and patient goals." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEF2F7;strokeColor=#A7B0BE;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="90" y="200" width="340" height="220" as="geometry" />
        </mxCell>
        <mxCell id="left_panel2" value="&lt;b&gt;Shared decision point&lt;/b&gt;&lt;br&gt;The best plan balances symptom relief, risk, recovery time, and long-term function." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="90" y="470" width="340" height="140" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;1. Understand the diagnosis&lt;/b&gt;&lt;br&gt;History, exam, imaging review, and goals" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="500" y="700" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;2. Conservative care&lt;/b&gt;&lt;br&gt;Activity changes, physical therapy, medication" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E9F7EF;strokeColor=#4C9A64;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="560" y="600" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_step1_step2" value="when needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#94A3B8;dashed=1;fontSize=11;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;3. Targeted pain relief&lt;/b&gt;&lt;br&gt;Injections or other guided nonoperative options" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E0F6F4;strokeColor=#138A8A;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="620" y="500" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_step2_step3" value="when needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#94A3B8;dashed=1;fontSize=11;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;4. Minimally invasive procedure&lt;/b&gt;&lt;br&gt;Smaller incisions when decompression or repair is needed" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFF4CC;strokeColor=#D6A300;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="680" y="400" width="660" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_step3_step4" value="when needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#94A3B8;dashed=1;fontSize=11;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="&lt;b&gt;5. Advanced spine surgery&lt;/b&gt;&lt;br&gt;Fusion, revision surgery, deformity care, robotics, or endoscopy when indicated" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFE8D6;strokeColor=#D97B2B;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="740" y="300" width="760" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_step4_step5" value="when needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#94A3B8;dashed=1;fontSize=11;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="&lt;b&gt;6. Follow-up and recovery&lt;/b&gt;&lt;br&gt;Function, pain control, safety, and return-to-life milestones" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEE9FB;strokeColor=#6D5BD0;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="800" y="200" width="660" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_step5_step6" value="when needed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#94A3B8;dashed=1;fontSize=11;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rung" value="Least invasive when appropriate" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#64748B;fontSize=12;fontStyle=1;fontColor=#138A8A;" vertex="1" parent="1">
          <mxGeometry x="520" y="790" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rung2" value="More advanced when symptoms, function, or safety require it" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#64748B;fontSize=12;fontStyle=1;fontColor=#D97B2B;" vertex="1" parent="1">
          <mxGeometry x="870" y="138" width="520" height="34" as="geometry" />
        </mxCell>
        <mxCell id="site_use" value="&lt;b&gt;Website use&lt;/b&gt;&lt;br&gt;Place near “conditions” or “treatments” as a neutral overview before procedure-specific pages." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFFFFF;strokeColor=#123E63;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="90" y="660" width="340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Patient-education draft for website review. Not a diagnosis, treatment recommendation, or emergency triage protocol. Clinical, legal, and brand review required before publication." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#64748B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="920" width="1520" height="36" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="365fb0a8-6939-4b87-ba35-8dfde8848de1" name="10 Website - Recovery Milestones">
    <mxGraphModel dx="1700" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;After Spine Surgery: Recovery Milestones&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="1620" height="66" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="A simple timeline patients can understand before or after a minimally invasive spine procedure." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#475569;fontSize=14;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="48" y="101" width="1604" height="44" as="geometry" />
        </mxCell>
        <mxCell id="timeline_base" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4FB;strokeColor=#2F80B7;strokeWidth=2;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="140" y="430" width="1420" height="28" as="geometry" />
        </mxCell>
        <mxCell id="t0_dot" value="Day 0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="390" width="84" height="84" as="geometry" />
        </mxCell>
        <mxCell id="t0" value="&lt;b&gt;Procedure day&lt;/b&gt;&lt;br&gt;Safety checks, pain plan, walking plan, and discharge instructions." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="160" y="520" width="230" height="118" as="geometry" />
        </mxCell>
        <mxCell id="e_t0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=none;strokeColor=#94A3B8;" edge="1" parent="1" source="t0_dot" target="t0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t1_dot" value="Days 1–7" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="390" width="84" height="84" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="&lt;b&gt;Protect and move&lt;/b&gt;&lt;br&gt;Short walks, incision care, medication safety, and warning signs." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E0F6F4;strokeColor=#138A8A;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="430" y="520" width="230" height="118" as="geometry" />
        </mxCell>
        <mxCell id="e_t1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=none;strokeColor=#94A3B8;" edge="1" parent="1" source="t1_dot" target="t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2_dot" value="Weeks 2–6" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="390" width="84" height="84" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="&lt;b&gt;Build routine&lt;/b&gt;&lt;br&gt;Increase walking, reduce pain medicine when appropriate, follow restrictions." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E9F7EF;strokeColor=#4C9A64;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="700" y="520" width="230" height="118" as="geometry" />
        </mxCell>
        <mxCell id="e_t2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=none;strokeColor=#94A3B8;" edge="1" parent="1" source="t2_dot" target="t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t3_dot" value="Weeks 6–12" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="390" width="84" height="84" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="&lt;b&gt;Function focus&lt;/b&gt;&lt;br&gt;Therapy, strength, posture, and return-to-activity planning." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFF4CC;strokeColor=#D6A300;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="970" y="520" width="230" height="118" as="geometry" />
        </mxCell>
        <mxCell id="e_t3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=none;strokeColor=#94A3B8;" edge="1" parent="1" source="t3_dot" target="t3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t4_dot" value="Ongoing" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1310" y="390" width="84" height="84" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="&lt;b&gt;Long-term spine habits&lt;/b&gt;&lt;br&gt;Core strength, safe lifting, follow-up imaging when ordered, and healthy movement." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEE9FB;strokeColor=#6D5BD0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1240" y="520" width="230" height="118" as="geometry" />
        </mxCell>
        <mxCell id="e_t4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=none;strokeColor=#94A3B8;" edge="1" parent="1" source="t4_dot" target="t4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="top_left" value="&lt;b&gt;Before discharge&lt;/b&gt;&lt;br&gt;Patients should know how to walk safely, manage medications, protect the incision, and contact the office." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEF2F7;strokeColor=#A7B0BE;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="165" y="185" width="440" height="120" as="geometry" />
        </mxCell>
        <mxCell id="top_right" value="&lt;b&gt;Call sooner if instructed symptoms occur&lt;/b&gt;&lt;br&gt;Examples may include worsening weakness, fever, wound concerns, chest pain, shortness of breath, or bowel / bladder changes." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FDE2E2;strokeColor=#B00020;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="185" width="480" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bottom_note" value="&lt;b&gt;Good website placement&lt;/b&gt;&lt;br&gt;Use below minimally invasive surgery pages. It sets expectations without overloading the patient with procedure-specific details." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFFFFF;strokeColor=#123E63;fontSize=14;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="435" y="745" width="830" height="92" as="geometry" />
