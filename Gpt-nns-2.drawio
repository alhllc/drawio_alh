        </mxCell>
        <mxCell id="card1" value="&lt;b&gt;Neck pain&lt;/b&gt;&lt;br&gt;Stiffness, headaches, or pain moving toward the shoulder / arm." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEE9FB;strokeColor=#6D5BD0;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="190" width="660" height="88" as="geometry" />
        </mxCell>
        <mxCell id="card2" value="&lt;b&gt;Back pain&lt;/b&gt;&lt;br&gt;Sharp, aching, or activity-related pain in the middle or lower back." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFE8D6;strokeColor=#D97B2B;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="320" width="660" height="88" as="geometry" />
        </mxCell>
        <mxCell id="card3" value="&lt;b&gt;Radiating symptoms&lt;/b&gt;&lt;br&gt;Numbness, tingling, burning, or electric-like pain into an arm or leg." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E0F6F4;strokeColor=#138A8A;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="450" width="660" height="88" as="geometry" />
        </mxCell>
        <mxCell id="card4" value="&lt;b&gt;Weakness or balance change&lt;/b&gt;&lt;br&gt;Trouble gripping, walking, lifting the foot, or standing safely." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFF4CC;strokeColor=#D6A300;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="580" width="660" height="88" as="geometry" />
        </mxCell>
        <mxCell id="card5" value="&lt;b&gt;Bring the pattern&lt;/b&gt;&lt;br&gt;Mark where symptoms start, where they travel, and what makes them better or worse." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="710" width="660" height="88" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;" edge="1" parent="1" source="neck_zone" target="card1">
          <mxGeometry relative="1" as="geometry" />
