  <diagram id="a8e54525-2571-43ff-a77b-1b91d55c9c8c" name="07 Website - When to See a Specialist">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;When Should I See a Spine Specialist?&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="1520" height="66" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="A calm decision guide that helps patients understand when a neurosurgical spine opinion may be appropriate." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#475569;fontSize=14;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="48" y="101" width="1504" height="44" as="geometry" />
        </mxCell>
        <mxCell id="start" value="&lt;b&gt;Back or neck pain?&lt;/b&gt;&lt;br&gt;Start by noticing duration, severity, nerve symptoms, and daily-life impact." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="160" width="300" height="96" as="geometry" />
        </mxCell>
        <mxCell id="urgent_q" value="New severe weakness, trouble walking, fever with spine pain, major trauma, or bowel / bladder change?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FDE2E2;strokeColor=#B00020;fontColor=#1F2937;fontSize=14;fontStyle=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="610" y="315" width="380" height="148" as="geometry" />
        </mxCell>
        <mxCell id="urgent" value="&lt;b&gt;Seek urgent medical care&lt;/b&gt;&lt;br&gt;Do not wait for a routine appointment." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FDE2E2;strokeColor=#B00020;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="345" width="310" height="88" as="geometry" />
        </mxCell>
        <mxCell id="nerve_q" value="Pain travels into an arm or leg, or includes numbness, tingling, burning, or weakness?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D6A300;fontColor=#1F2937;fontSize=14;fontStyle=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="610" y="520" width="380" height="148" as="geometry" />
        </mxCell>
        <mxCell id="specialist" value="&lt;b&gt;Consider a specialist consult&lt;/b&gt;&lt;br&gt;A spine-focused exam can match symptoms to imaging and options." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEE9FB;strokeColor=#6D5BD0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="550" width="310" height="96" as="geometry" />
        </mxCell>
        <mxCell id="time_q" value="Pain persists, returns often, or limits work, sleep, walking, or hobbies?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E0F6F4;strokeColor=#138A8A;fontColor=#1F2937;fontSize=14;fontStyle=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="610" y="725" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="routine" value="&lt;b&gt;Schedule a spine evaluation&lt;/b&gt;&lt;br&gt;Bring imaging, medications, and a short symptom timeline." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E0F6F4;strokeColor=#138A8A;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="748" width="310" height="96" as="geometry" />
        </mxCell>
        <mxCell id="selfcare" value="&lt;b&gt;Monitor and use conservative care&lt;/b&gt;&lt;br&gt;Activity changes, physical therapy, and clinician-guided medication may help many patients." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E9F7EF;strokeColor=#4C9A64;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="732" width="310" height="112" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;" edge="1" parent="1" source="start" target="urgent_q">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#B00020;" edge="1" parent="1" source="urgent_q" target="urgent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;" edge="1" parent="1" source="urgent_q" target="nerve_q">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#6D5BD0;" edge="1" parent="1" source="nerve_q" target="specialist">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;" edge="1" parent="1" source="nerve_q" target="time_q">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;strokeColor=#138A8A;" edge="1" parent="1" source="time_q" target="routine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;" edge="1" parent="1" source="time_q" target="selfcare">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="explain" value="&lt;b&gt;Why this works on the site&lt;/b&gt;&lt;br&gt;It reduces uncertainty without promising an outcome. It also supports the practice message that both surgical and nonsurgical options may be considered." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEF2F7;strokeColor=#A7B0BE;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="135" y="190" width="340" height="126" as="geometry" />
        </mxCell>
        <mxCell id="cta" value="&lt;b&gt;Suggested CTA module&lt;/b&gt;&lt;br&gt;“Questions about your diagnosis? Bring your imaging and ask about your options.”" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFFFFF;strokeColor=#123E63;fontSize=14;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="135" y="365" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Patient-education draft for website review. Not a diagnosis, treatment recommendation, or emergency triage protocol. Clinical, legal, and brand review required before publication." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#64748B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="920" width="1520" height="36" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="98c2d2fe-1fea-4d42-9684-8be33670a260" name="08 Website - First Visit Prep">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;First Visit Prep: What to Bring&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="1520" height="66" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="A website-ready checklist that turns appointment instructions into a compact visual patients can save or print." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#475569;fontSize=14;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="48" y="101" width="1504" height="44" as="geometry" />
        </mxCell>
        <mxCell id="intro" value="&lt;b&gt;Your first visit is easier when the story is organized.&lt;/b&gt;&lt;br&gt;Use this checklist before a spine or brain consultation." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#123E63;strokeColor=#123E63;fontColor=#FFFFFF;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="155" width="1360" height="72" as="geometry" />
        </mxCell>
        <mxCell id="prep1_num" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="280" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep1" value="&lt;b&gt;Imaging&lt;/b&gt;&lt;br&gt;MRI / CT / X-ray CDs and reports, sent before the visit when possible." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EAF4FB;strokeColor=#2F80B7;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="225" y="268" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="prep2_num" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="280" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep2" value="&lt;b&gt;Symptom timeline&lt;/b&gt;&lt;br&gt;When it started, what changed, and what you can no longer do comfortably." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E0F6F4;strokeColor=#138A8A;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="645" y="268" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="prep3_num" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="280" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep3" value="&lt;b&gt;Medication list&lt;/b&gt;&lt;br&gt;Include blood thinners, heart medications, pain medicines, supplements, and allergies." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#E9F7EF;strokeColor=#4C9A64;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1065" y="268" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="prep4_num" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="530" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep4" value="&lt;b&gt;Prior treatments&lt;/b&gt;&lt;br&gt;Physical therapy, injections, chiropractic care, surgery, braces, or medications tried." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEE9FB;strokeColor=#6D5BD0;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="225" y="518" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="prep5_num" value="5" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="530" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep5" value="&lt;b&gt;Daily-life goals&lt;/b&gt;&lt;br&gt;Work, sleep, walking, lifting, sports, caregiving, travel, and safety concerns." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFF4CC;strokeColor=#D6A300;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="645" y="518" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="prep6_num" value="6" style="ellipse;whiteSpace=wrap;html=1;fillColor=#0B2D4D;strokeColor=#0B2D4D;fontColor=#FFFFFF;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="530" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="prep6" value="&lt;b&gt;Questions&lt;/b&gt;&lt;br&gt;What diagnosis fits? What are nonsurgical options? When is surgery considered?" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#FFE8D6;strokeColor=#D97B2B;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1065" y="518" width="315" height="112" as="geometry" />
        </mxCell>
        <mxCell id="bottom" value="&lt;b&gt;Appointment mindset&lt;/b&gt;&lt;br&gt;Diagnosis + options + shared plan. The goal is to connect symptoms, imaging, safety, lifestyle, and future plans." style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#1F2937;arcSize=12;spacing=8;fillColor=#EEF2F7;strokeColor=#A7B0BE;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="770" width="1120" height="82" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep1" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep2" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep3" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep4" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep5" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;endArrow=classic;strokeColor=#6B7280;fontSize=12;fontColor=#475569;dashed=1;endArrow=none;" edge="1" parent="1" source="prep6" target="bottom">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Patient-education draft for website review. Not a diagnosis, treatment recommendation, or emergency triage protocol. Clinical, legal, and brand review required before publication." style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;fontColor=#64748B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="920" width="1520" height="36" as="geometry" />
        </mxCell>
      </root>
